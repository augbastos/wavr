.venv/
__pycache__/
*.pyc
*.db
.env
.pytest_cache/
node_modules/
*.pt
*.egg-info/
.wrangler/
.playwright-mcp/

# graphify generated index (do not commit)
graphify-out/

# SQLite runtime DB (never commit)
wavr.db
wavr.db-shm
wavr.db-wal
backend/wavr.db
backend/wavr.db-shm
backend/wavr.db-wal

# A5.1 optional local-API token (WAVR_LOCAL_TOKEN=auto persists the RAW shared
# secret beside the db as an extensionless `local_token` file -- NOT matched by
# *.db / wavr.db*). Never commit a live credential to this public AGPL repo.
local_token
**/local_token
backend/local_token

# tool-output dirs (never commit)
_fable/
.superpowers/

# F4 autostart runner logs -- backend stdout/stderr may pass through here; never commit
# to this public AGPL repo (wavr.db-wal PII-leak precedent).
logs/

# local competitive research — contains real home-network PII (subnet/hostnames/VPN IPs);
# keep OUT of this public repo until redacted (audit 2026-07-04)
docs/competitive-analysis/

# the user's real floor plan — home-layout PII, never publish (2026-07-05)
# F1: WAVR_HOUSE_MAP defaults to a bare cwd-relative "house.json"; the bare pattern
# already matches backend/house.json recursively, listed explicitly (wavr.db* style).
house.json
backend/house.json

# ---- Wavr Mobile (Capacitor) — public-repo hygiene, before the files exist ----
# Signing material — NEVER commit to this public AGPL repo (upload keystore + key config).
# (global node_modules/ above already covers mobile/node_modules/.)
*.jks
*.keystore
key.properties
keystore.properties
# Per-machine Android SDK path — never commit.
local.properties
# Generated web bundle: `npm run sync-frontend` copies frontend/index.html + vendor +
# the shim into mobile/www/. Regenerated by build, versioned by app updates, never commit.
mobile/www/
# Capacitor copies www + config into the Android assets on `cap sync` — regenerated.
mobile/android/app/src/main/assets/public/
mobile/android/app/src/main/assets/capacitor.config.json
mobile/android/app/src/main/assets/capacitor.plugins.json
# Android / Gradle build outputs (the android/ project itself IS committed, minus these).
mobile/android/build/
mobile/android/app/build/
mobile/android/.gradle/
mobile/android/captures/
mobile/android/.idea/
mobile/android/app/release/
mobile/android/app/debug/
mobile/android/local.properties

# --- local-only: build artifacts (never public) ---
core-launcher/app/build/
core-launcher/.gradle/
core-launcher/local.properties
desktop/src-tauri/target/
# --- local-only: private notes, logs, scratch (never public) ---
docs/ROADMAP.md
docs/stack-netdoctor/
docs/feedback-sim/
